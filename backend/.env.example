# UNVEILED Backend Environment Variables
# Copy this file to .env and fill in your free API keys
# NEVER commit .env to git

# HuggingFace (free) — huggingface.co → Settings → Access Tokens
HF_API_TOKEN=hf_your_token_here

# Google Gemini Flash (free, 1500 calls/day) — aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (free, Llama 3.1 70B) — console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Adzuna Jobs API (free, 1000 calls/day) — developer.adzuna.com
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# Supabase (free, 500MB forever) — supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# App settings
ENVIRONMENT=production
ALLOWED_ORIGINS=*
